# Copy to .env.local and fill in. .env.local is gitignored.
# Used by the sync CLI (scripts/sync.mjs) and `npm run sync:*`.

# Your deployed Worker URL (from `wrangler deploy`):
SYNC_URL=https://planoflife-sync.YOUR-SUBDOMAIN.workers.dev

# Your sync passphrase. This is also your end-to-end encryption key —
# the Worker never sees it. Use the SAME passphrase you enter in the app.
SYNC_PASSPHRASE=change-me
